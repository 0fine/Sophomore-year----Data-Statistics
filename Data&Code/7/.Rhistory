pre <- c(6,10,3,5,7)
post <- c(1,2,0,5,2)
#检验数据是否服从正态分布
shapiro.test(pre)
shapiro.test(post)
#one-sample t-test:单样本t检验
t.test(pre, mu=5)  #mu假定该数据平均值为5
#paired-sample t-test:配对样本t检验
t.test(pre,post,alternative = "two.sided",paired = TRUE)
